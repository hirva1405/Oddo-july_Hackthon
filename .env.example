# Copy this file to .env before running the server

PORT=5000

# Secret used to sign JWT access tokens - change this to a long random string in production
JWT_SECRET=replace_this_with_a_long_random_secret_key
JWT_EXPIRES_IN=1d

# Secret used to sign JWT refresh tokens
JWT_REFRESH_SECRET=replace_this_with_a_different_long_random_secret_key
JWT_REFRESH_EXPIRES_IN=7d

# bcrypt salt rounds
BCRYPT_SALT_ROUNDS=10
